{
  "name": "serraui",
  "version": "1.0.0",
  "description": "CLI customizado da Serra Jr. Engenharia para instalar componentes UI",
  "main": "dist/index.js",
  "bin": {
    "serraui": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --clean",
    "dev": "tsup src/index.ts --format cjs --watch",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "node-fetch": "^2.7.0",
    "ora": "^5.4.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.9",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2"
  }
}
